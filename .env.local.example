# Copia este archivo a .env.local y llena los valores reales (nunca commitees .env.local).
# Si usas la integración Vercel↔Supabase, las variables vienen con prefijo PANINIJD_*.
# Mapea:
#   NEXT_PUBLIC_SUPABASE_URL       <- PANINIJD_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  <- PANINIJD_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY      <- PANINIJD_SUPABASE_SERVICE_ROLE_KEY (solo server!)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Opcional, para Supabase CLI o scripts directos a DB
POSTGRES_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
